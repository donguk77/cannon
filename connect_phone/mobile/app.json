{
  "expo": {
    "name": "Canon Monitor",
    "slug": "canon-monitor-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.canonmonitor.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "카메라로 모니터 화면을 분석합니다.",
          "enableFrameProcessors": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "usesCleartextTraffic": true
          }
        }
      ],
      "./plugins/withGradleWrapper",
      "./plugins/withMavenRepositories",
      "./plugins/withGradleInit"
    ],
    "extra": {
      "eas": {
        "projectId": "7874aedd-42a7-4517-8f82-04ea104a0386"
      }
    },
    "owner": "donguknan"
  }
}
